#     priority: 10

# ──────────────────────────────────────────────────────────────────────────────
# Design System Overrides (optional)
# Override default responsive breakpoints or design token extraction behavior
# ──────────────────────────────────────────────────────────────────────────────
config:
  breakpoints:
    xs: "0px"
    sm: "576px"
    md: "768px"
    lg: "992px"
  extract_design_tokens: true
  extract_typography: true
  extract_colors: true
  extract_spacing: true
  placeholder_images: true
  ssr_compatible: true
  seo_optimized: true
